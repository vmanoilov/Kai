    <string name="settings_daemon_mode">Λειτουργία Daemon</string>
    <string name="settings_daemon_mode_description">Διατηρήστε το Kai 9000 σε λειτουργία στο παρασκήνιο ώστε οι προγραμματισμένες εργασίες να εκτελούνται ακόμα και όταν η εφαρμογή δεν είναι στο προσκήνιο.</string>
